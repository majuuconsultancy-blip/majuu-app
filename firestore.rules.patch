rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authUid() {
      return request.auth.uid;
    }

    function str(v) {
      return v is string ? v : "";
    }

    function lower(v) {
      return str(v).lower();
    }

    function isSelf(uid) {
      return signedIn() && authUid() == uid;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userExists(uid) {
      return exists(userPath(uid));
    }

    function userDoc(uid) {
      return userExists(uid) ? get(userPath(uid)).data : null;
    }

    function userRole(uid) {
      return userExists(uid) ? lower(userDoc(uid).role) : "";
    }

    function isSuperAdmin() {
      return signedIn() && (
        (
          request.auth.token.email != null
          && lower(request.auth.token.email) == "brioneroo@gmail.com"
        ) ||
        userRole(authUid()) == "superadmin" ||
        userRole(authUid()) == "super_admin"
      );
    }

    function isAssignedAdmin() {
      return signedIn() && (
        userRole(authUid()) == "assignedadmin" ||
        userRole(authUid()) == "assigned_admin" ||
        userRole(authUid()) == "admin"
      );
    }

    function isAnyAdmin() {
      return isSuperAdmin() || isAssignedAdmin();
    }

    function isSafeSelfUserCreate(uid) {
      return isSelf(uid) && (
        !request.resource.data.keys().hasAny(["role"]) ||
        lower(request.resource.data.role) == "user"
      );
    }

    function isSafeSelfUserUpdate(uid) {
      return isSelf(uid) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.adminScope == resource.data.adminScope;
    }

    function fullPackagePath(fullPackageId) {
      return /databases/$(database)/documents/fullPackages/$(fullPackageId);
    }

    function fullPackageExists(fullPackageId) {
      return str(fullPackageId).size() > 0 && exists(fullPackagePath(fullPackageId));
    }

    function fullPackageOwner(fullPackageId) {
      return fullPackageExists(fullPackageId)
        ? get(fullPackagePath(fullPackageId)).data.uid
        : null;
    }

    function validFullPackageLinkOnCreate() {
      return !(request.resource.data.isFullPackage == true)
        || (
          str(request.resource.data.fullPackageId).size() > 0
          && fullPackageExists(str(request.resource.data.fullPackageId))
          && fullPackageOwner(str(request.resource.data.fullPackageId)) == authUid()
        );
    }

    function clientRequestFinanceFieldsSafeOnCreate() {
      return (
        (!request.resource.data.keys().hasAny(["paid"]) || request.resource.data.paid == false)
        && (!request.resource.data.keys().hasAny(["paymentMeta"]) || request.resource.data.paymentMeta == null)
        && (!request.resource.data.keys().hasAny(["unlockPaymentId"]) || str(request.resource.data.unlockPaymentId) == "")
        && (!request.resource.data.keys().hasAny(["unlockPaymentRequestId"]) || str(request.resource.data.unlockPaymentRequestId) == "")
        && (!request.resource.data.keys().hasAny(["paymentFlowType"]) || str(request.resource.data.paymentFlowType) == "")
        && (!request.resource.data.keys().hasAny(["unlockAutoRefundEligibleAtMs"]) || request.resource.data.unlockAutoRefundEligibleAtMs == 0)
        && (!request.resource.data.keys().hasAny(["unlockAutoRefundStatus"]) || str(request.resource.data.unlockAutoRefundStatus) == "")
      );
    }

    function clientRequestRoutingFieldsSafeOnCreate() {
      return (
        str(request.resource.data.assignedPartnerId) == ""
        && str(request.resource.data.assignedPartnerName) == ""
        && str(request.resource.data.assignedAdminId) == ""
        && str(request.resource.data.currentAdminUid) == ""
        && str(request.resource.data.currentAdminRole) == ""
        && str(request.resource.data.currentAdminEmail) == ""
        && str(request.resource.data.currentAdminAvailability) == ""
        && str(request.resource.data.ownerLockedAdminUid) == ""
        && str(request.resource.data.routingStatus) in ["awaiting_route", "awaiting_payment", ""]
        && (
          !request.resource.data.keys().hasAny(["routingMeta"])
          || (
            str(request.resource.data.routingMeta.currentAdminUid) == ""
            && str(request.resource.data.routingMeta.currentAdminEmail) == ""
            && str(request.resource.data.routingMeta.assignedAdminId) == ""
            && str(request.resource.data.routingMeta.assignedPartnerId) == ""
            && str(request.resource.data.routingMeta.assignedPartnerName) == ""
            && str(request.resource.data.routingMeta.lockedOwnerAdminUid) == ""
            && str(request.resource.data.routingMeta.routingStatus) in ["awaiting_route", "awaiting_payment", ""]
          )
        )
      );
    }

    function fullPackageOwnerCreateSafe() {
      return request.resource.data.uid == authUid()
        && request.resource.data.unlockPaid != true
        && request.resource.data.depositPaid != true
        && (!request.resource.data.keys().hasAny(["unlockPaymentMeta"]) || request.resource.data.unlockPaymentMeta == null)
        && (!request.resource.data.keys().hasAny(["depositPaymentMeta"]) || request.resource.data.depositPaymentMeta == null)
        && (!request.resource.data.keys().hasAny(["unlockCoverage"]) || request.resource.data.unlockCoverage == null)
        && (!request.resource.data.keys().hasAny(["latestUnlockRequestId"]) || str(request.resource.data.latestUnlockRequestId) == "")
        && (!request.resource.data.keys().hasAny(["latestUnlockItemsKey"]) || str(request.resource.data.latestUnlockItemsKey) == "");
    }

    function fullPackageOwnerUpdateSafe() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "email",
          "track",
          "country",
          "selectedItems",
          "itemStates",
          "updatedAt",
          "updatedAtMs"
        ]);
    }

    function requestPath(requestId) {
      return /databases/$(database)/documents/serviceRequests/$(requestId);
    }

    function requestExists(requestId) {
      return exists(requestPath(requestId));
    }

    function requestDoc(requestId) {
      return requestExists(requestId) ? get(requestPath(requestId)).data : null;
    }

    function requestOwner(requestId) {
      return requestExists(requestId) ? requestDoc(requestId).uid : null;
    }

    function requestAssignedTo(requestId) {
      return requestExists(requestId) ? requestDoc(requestId).assignedTo : null;
    }

    function requestStatus(requestId) {
      return requestExists(requestId) ? requestDoc(requestId).status : "";
    }

    function requestIsFinalized(requestId) {
      return requestStatus(requestId) == "closed" || requestStatus(requestId) == "rejected";
    }

    function requestFinalizedOrDone(requestId) {
      return requestExists(requestId) && (
        requestDoc(requestId).staffStatus == "done" ||
        requestIsFinalized(requestId)
      );
    }

    function isRequestOwner(requestId) {
      return signedIn() && requestExists(requestId) && requestOwner(requestId) == authUid();
    }

    function isRequestAssignedStaff(requestId) {
      return signedIn() && requestExists(requestId) && requestAssignedTo(requestId) == authUid();
    }

    function isScopedAssignedAdminForRequestData(data) {
      return isAssignedAdmin() && data != null && (
        data.currentAdminUid == authUid() ||
        data.ownerLockedAdminUid == authUid() ||
        data.assignedAdminId == authUid() ||
        data.routingMeta.currentAdminUid == authUid() ||
        data.routingMeta.assignedAdminId == authUid()
      );
    }

    function canAdminAccessRequest(requestId) {
      return isSuperAdmin() || (
        isAssignedAdmin() &&
        requestExists(requestId) &&
        isScopedAssignedAdminForRequestData(requestDoc(requestId))
      );
    }

    function canReadRequestData(data) {
      return data != null && (
        isSuperAdmin() ||
        isScopedAssignedAdminForRequestData(data) ||
        (signedIn() && data.uid == authUid()) ||
        (signedIn() && data.assignedTo == authUid())
      );
    }

    function staffPath(staffUid) {
      return /databases/$(database)/documents/staff/$(staffUid);
    }

    function staffExists(staffUid) {
      return exists(staffPath(staffUid));
    }

    function staffDoc(staffUid) {
      return staffExists(staffUid) ? get(staffPath(staffUid)).data : null;
    }

    function isAssignedAdminForStaff(staffUid) {
      return isAssignedAdmin() &&
        staffExists(staffUid) &&
        staffDoc(staffUid).ownerAdminUid == authUid();
    }

    // Query-safe ownership check for /staff list reads
    function isAssignedAdminOwnerOfStaffDoc(data) {
      return isAssignedAdmin()
        && data != null
        && data.ownerAdminUid != null
        && data.ownerAdminUid == authUid();
    }

    function canAdminAccessStaff(staffUid) {
      return isSuperAdmin() || isAssignedAdminForStaff(staffUid);
    }

    function changedHas(field) {
      return request.resource.data.diff(resource.data).changedKeys().hasAny([field]);
    }

    function staffAllowedRequestStatus(newStatus) {
      return newStatus in ["new", "contacted"];
    }

    function staffAllowedBackendStatus(newStatus) {
      return newStatus in ["new", "assigned", "in_progress", "completed"];
    }

    function staffAllowedUserStatus(newStatus) {
      return newStatus in ["", "in_progress", "completed"];
    }

    function staffAllowedStaffStatus(v) {
      return v in ["assigned", "in_progress", "done"];
    }

    function staffAllowedDecision(v) {
      return v in ["recommend_accept", "recommend_reject", "none"];
    }

    function staffAllowedProgressPercent(v) {
      return v in [10, 20, 30, 40, 50, 60, 70, 80, 90];
    }

    function chatTypeOk(t) {
      return t in ["text", "pdf", "bundle"];
    }

    function chatRoleOk(r) {
      return r in ["user", "staff", "admin"];
    }

    match /analytics_helpChoices/{id} {
      allow create: if signedIn()
        && request.resource.data.choice in ["self", "we"]
        && request.resource.data.uid == authUid();

      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /analytics_customCountryDemand/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == authUid()
        && request.resource.data.track in ["study", "work", "travel", ""]
        && str(request.resource.data.country).size() > 0
        && str(request.resource.data.countryKey).size() > 0;

      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /analytics_customCountryDemandCounts/{countryKey} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;

      match /users/{uid} {
        allow read: if isSuperAdmin();
        allow create, update, delete: if false;
      }
    }

    match /analytics_events/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == authUid()
        && str(request.resource.data.eventType).size() > 0;

      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /analytics_countryDemand/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == authUid()
        && request.resource.data.track in ["study", "work", "travel", ""]
        && str(request.resource.data.country).size() > 0
        && str(request.resource.data.countryKey).size() > 0;

      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /analytics_countryDemandCounts/{countryKey} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;

      match /users/{uid} {
        allow read: if isSuperAdmin();
        allow create, update, delete: if false;
      }
    }

    match /analytics_newsRouteViews/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == authUid()
        && request.resource.data.track in ["study", "work", "travel"]
        && str(request.resource.data.country).size() > 0
        && str(request.resource.data.countryKey).size() > 0
        && str(request.resource.data.routeKey).size() > 0;

      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /analytics_newsRouteViewCounts/{routeKey} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;

      match /users/{uid} {
        allow read: if isSuperAdmin();
        allow create, update, delete: if false;
      }
    }

    match /analytics_newsCountryViewCounts/{countryKey} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;

      match /users/{uid} {
        allow read: if isSuperAdmin();
        allow create, update, delete: if false;
      }
    }

    match /analytics_selfHelpLinkClicks/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == authUid()
        && request.resource.data.track in ["study", "work", "travel"]
        && str(request.resource.data.country).size() > 0;

      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /analytics_selfHelpLinkClickCounts/{bucket} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /analytics_selfHelpOutbounds/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == authUid()
        && str(request.resource.data.resourceId).size() > 0;

      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /news/{newsId} {
      allow read: if isSuperAdmin() || (signedIn() && resource.data.isPublished == true);
      allow create, update, delete: if isSuperAdmin();
    }

    match /pricingRules/{pricingKey} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /requestDefinitions/{definitionId} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /countries/{countryId} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /partners/{partnerId} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /partnerCoverage/{partnerId} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /financeSettings/{configId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /partnerFinancialProfiles/{partnerId} {
      allow read: if isAnyAdmin();
      allow create, update: if isAnyAdmin();
      allow delete: if isSuperAdmin();
    }

    match /payoutQueue/{queueId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if false;
    }

    match /settlementHistory/{settlementId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if false;
    }

    match /financialAuditLogs/{auditId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if false;
    }

    match /paymentProviderReferences/{referenceId} {
      allow read, create, update, delete: if false;
    }

    match /paymentShareLinks/{shareId} {
      allow read, create, update, delete: if false;
    }

    match /paymentProviderEvents/{eventId} {
      allow read, create, update, delete: if false;
    }

    match /selfHelpLinks/{resourceId} {
      allow read: if signedIn();
      allow create, delete: if isSuperAdmin();

      allow update: if isSuperAdmin()
        || (
          signedIn()
          && request.resource.data.id == resource.data.id
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "clickCount",
            "lastClickedAt",
            "updatedAt",
            "updatedAtMs"
          ])
          && request.resource.data.clickCount is number
          && resource.data.clickCount is number
          && request.resource.data.clickCount == resource.data.clickCount + 1
        );
    }

    match /users/{uid} {
      allow read: if isAnyAdmin() || isSelf(uid);
      allow create: if isSuperAdmin() || isSafeSelfUserCreate(uid);
      allow update: if isSuperAdmin() || isSafeSelfUserUpdate(uid);
      allow delete: if false;

      match /pushTokens/{tokenId} {
        allow read: if isSelf(uid) || isAnyAdmin();

        allow create, update: if (isSelf(uid) || isAnyAdmin())
          && request.resource.data.uid == uid
          && request.resource.data.role in ["user", "staff", "admin"]
          && request.resource.data.platform in ["android", "ios", "web"]
          && str(request.resource.data.token).size() >= 20;

        allow delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isAnyAdmin() || isSelf(uid);
        allow create: if isAnyAdmin();

        allow update: if isAnyAdmin()
          || (isSelf(uid)
              && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readAt"]));

        allow delete: if isAnyAdmin() || isSelf(uid);
      }

      match /selfHelp/{docId} {
        allow read: if isAnyAdmin() || isSelf(uid);

        allow create, update: if isSuperAdmin()
          || (
            isSelf(uid)
            && docId == "memory"
          );

        allow delete: if false;
      }

      match /selfHelpRoutes/{routeId} {
        allow read: if isAnyAdmin() || isSelf(uid);

        allow create, update: if isSuperAdmin()
          || (
            isSelf(uid)
            && request.resource.data.id == routeId
            && request.resource.data.track in ["study", "work", "travel"]
            && str(request.resource.data.country).size() > 0
            && request.resource.data.completedStepIds is list
            && request.resource.data.moneyTools is map
          );

        allow delete: if false;
      }

      match /selfHelpDocuments/{docId} {
        allow read: if isAnyAdmin() || isSelf(uid);

        allow create, update: if isSuperAdmin()
          || (
            isSelf(uid)
            && request.resource.data.id == docId
            && request.resource.data.track in ["study", "work", "travel"]
            && str(request.resource.data.country).size() > 0
            && str(request.resource.data.category).size() > 0
          );

        allow delete: if isSuperAdmin() || isSelf(uid);
      }
    }

    match /staff/{staffUid} {
      // Use resource.data here so Firestore can authorize list queries.
      allow read: if isSuperAdmin()
        || isSelf(staffUid)
        || isAssignedAdminOwnerOfStaffDoc(resource.data)
        // Allow assigned admins to probe a missing staff doc before creating it.
        || (isAssignedAdmin() && !staffExists(staffUid));

      allow create: if isSuperAdmin()
        || (isAssignedAdmin() && request.resource.data.ownerAdminUid == authUid())
        || (isSelf(staffUid) && request.resource.data.keys().hasOnly(["uid"]));

      allow update: if isSuperAdmin()
        || isAssignedAdminForStaff(staffUid)
        || (
          isAssignedAdmin()
          && str(resource.data.ownerAdminUid).size() == 0
          && request.resource.data.ownerAdminUid == authUid()
        )
        || (
          isSelf(staffUid)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "onboarded",
            "onboardingAccepted",
            "onboardingAcceptedAt",
            "onboardingVersion",
            "updatedAt"
          ])
        );

      allow delete: if isSuperAdmin() || isAssignedAdminForStaff(staffUid);

      match /pushTokens/{tokenId} {
        allow read: if isSelf(staffUid) || canAdminAccessStaff(staffUid);

        allow create, update: if isSelf(staffUid)
          && request.resource.data.uid == staffUid
          && request.resource.data.role in ["user", "staff", "admin"]
          && request.resource.data.platform in ["android", "ios", "web"]
          && str(request.resource.data.token).size() >= 20;

        allow delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if canAdminAccessStaff(staffUid) || isSelf(staffUid);
        allow create: if canAdminAccessStaff(staffUid);

        allow update: if canAdminAccessStaff(staffUid)
          || (isSelf(staffUid)
              && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readAt"]));

        allow delete: if canAdminAccessStaff(staffUid) || isSelf(staffUid);
      }

      match /tasks/{requestId} {
        allow read: if canAdminAccessStaff(staffUid) || isSelf(staffUid);

        allow create, update: if (
          isSuperAdmin() ||
          (isAssignedAdminForStaff(staffUid) && canAdminAccessRequest(requestId))
        ) || (
          isSelf(staffUid)
          && requestExists(requestId)
          && requestAssignedTo(requestId) == staffUid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "doneAt",
            "doneAtMs",
            "startedAt",
            "startedAtMs",
            "completedAt",
            "workMinutes",
            "staffDecision"
          ])
          && request.resource.data.status in ["assigned", "active", "done"]
          && (
            !changedHas("staffDecision")
            || request.resource.data.staffDecision == null
            || staffAllowedDecision(request.resource.data.staffDecision)
          )
        );

        allow delete: if (
          isSuperAdmin() ||
          (isAssignedAdminForStaff(staffUid) && canAdminAccessRequest(requestId))
        ) || (
          isSelf(staffUid)
          && (
            resource.data.status == "done" ||
            requestFinalizedOrDone(requestId)
          )
        );
      }
    }

    match /fullPackages/{fullPackageId} {
      allow read: if isSuperAdmin() || (signedIn() && resource.data.uid == authUid());
      allow create: if signedIn() && fullPackageOwnerCreateSafe();
      allow update: if isSuperAdmin()
        || (signedIn() && resource.data.uid == authUid() && fullPackageOwnerUpdateSafe());
      allow delete: if isSuperAdmin() || (signedIn() && resource.data.uid == authUid());
    }

    match /workflowDrafts/{draftId} {
      function workflowDraftIsPaid(data) {
        return data != null && (
          data.fullPackageUnlockPaid == true ||
          lower(data.paymentState) == "paid" ||
          lower(data.status) == "unlock_paid_pending_submission" ||
          lower(data.status) == "full_package_paid_pending_diagnostics"
        );
      }

      allow read: if isSuperAdmin() || (signedIn() && resource.data.uid == authUid());

      allow create: if signedIn()
        && request.resource.data.uid == authUid();

      allow update: if isSuperAdmin()
        || (
          signedIn()
          && resource.data.uid == authUid()
          && request.resource.data.uid == resource.data.uid
        );

      allow delete: if isSuperAdmin()
        || (
          signedIn()
          && resource.data.uid == authUid()
          && !workflowDraftIsPaid(resource.data)
        );
    }

    match /serviceRequests/{requestId} {
      function requestOwnerCanDeletePendingRequest() {
        return isRequestOwner(requestId)
          && requestExists(requestId)
          && requestDoc(requestId).paid != true
          && lower(requestDoc(requestId).status) == "payment_pending";
      }

      function unlockPaymentPath(paymentId) {
        return /databases/$(database)/documents/serviceRequests/$(requestId)/payments/$(paymentId);
      }

      function unlockPaymentExists(paymentId) {
        return str(paymentId).size() > 0 && exists(unlockPaymentPath(paymentId));
      }

      function unlockPaymentDoc(paymentId) {
        return unlockPaymentExists(paymentId)
          ? get(unlockPaymentPath(paymentId)).data
          : null;
      }

      function ownerCanFinalizeUnlockRequest() {
        let paymentId = str(request.resource.data.unlockPaymentId);
        let paymentData = unlockPaymentDoc(paymentId);
        return requestOwnerCanDeletePendingRequest()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "paid",
            "status",
            "routingStatus",
            "paymentMeta",
            "unlockPaymentId",
            "unlockPaymentRequestId",
            "updatedAt",
            "updatedAtMs"
          ])
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.paid == true
          && request.resource.data.status == "new"
          && request.resource.data.routingStatus == "awaiting_route"
          && request.resource.data.unlockPaymentRequestId == requestId
          && request.resource.data.paymentMeta != null
          && lower(request.resource.data.paymentMeta.status) == "paid"
          && str(request.resource.data.paymentMeta.requestId) == requestId
          && str(request.resource.data.paymentMeta.paymentId) == paymentId
          && paymentData != null
          && lower(paymentData.paymentType) == "unlock_request"
          && paymentData.requestId == requestId
          && paymentData.requestUid == authUid()
          && lower(paymentData.status) == "paid";
      }

      allow read: if canReadRequestData(resource.data);

      allow create: if signedIn()
        && request.resource.data.uid == authUid()
        && request.resource.data.county is string
        && request.resource.data.county.size() > 0
        && validFullPackageLinkOnCreate()
        && clientRequestFinanceFieldsSafeOnCreate()
        && clientRequestRoutingFieldsSafeOnCreate();

      allow update: if isSuperAdmin()
        || (
          isScopedAssignedAdminForRequestData(resource.data)
          && request.resource.data.currentAdminUid == resource.data.currentAdminUid
          && request.resource.data.currentAdminRole == resource.data.currentAdminRole
          && request.resource.data.currentAdminEmail == resource.data.currentAdminEmail
          && (
            request.resource.data.ownerLockedAdminUid == resource.data.ownerLockedAdminUid
            || request.resource.data.ownerLockedAdminUid == authUid()
          )
        )
        || ownerCanFinalizeUnlockRequest()
        || (
          isRequestAssignedStaff(requestId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "staffNote",
            "staffUpdatedAt",
            "staffStatus",
            "staffDecision",
            "staffStartedAt",
            "staffStartedAtMs",
            "staffStartedBy",
            "markedInProgressAt",
            "markedInProgressAtMs",
            "staffCompletedAt",
            "staffCompletedAtMs",
            "staffCompletedBy",
            "staffWorkMinutes",
            "staffProgressPercent",
            "staffProgressUpdatedAt",
            "staffProgressUpdatedAtMs",
            "backendStatus",
            "userStatus",
            "everAssigned",
            "updatedAt"
          ])
          && (
            !changedHas("status")
            || staffAllowedRequestStatus(request.resource.data.status)
          )
          && (
            !changedHas("staffStatus")
            || staffAllowedStaffStatus(request.resource.data.staffStatus)
          )
          && (
            !changedHas("staffDecision")
            || staffAllowedDecision(request.resource.data.staffDecision)
          )
          && (
            !changedHas("staffProgressPercent")
            || staffAllowedProgressPercent(request.resource.data.staffProgressPercent)
          )
          && (
            !changedHas("backendStatus")
            || staffAllowedBackendStatus(request.resource.data.backendStatus)
          )
          && (
            !changedHas("userStatus")
            || staffAllowedUserStatus(request.resource.data.userStatus)
          )
          && (
            !changedHas("everAssigned")
            || request.resource.data.everAssigned == true
            || request.resource.data.everAssigned == resource.data.everAssigned
          )
        );

      allow delete: if isSuperAdmin()
        || (
          isRequestOwner(requestId)
          && (requestIsFinalized(requestId) || requestOwnerCanDeletePendingRequest())
        );

      match /assignmentAudit/{auditId} {
        allow read, create: if canAdminAccessRequest(requestId);
        allow update, delete: if false;
      }

      match /requestHistory/{historyId} {
        allow read, create: if canAdminAccessRequest(requestId);
        allow update, delete: if false;
      }

      match /progressUpdates/{updateId} {
        allow read: if canAdminAccessRequest(requestId)
          || isRequestAssignedStaff(requestId)
          || (isRequestOwner(requestId) && resource.data.visibleToUser == true);

        allow create: if canAdminAccessRequest(requestId)
          || (
            isRequestAssignedStaff(requestId)
            && request.resource.data.requestId == requestId
            && request.resource.data.staffId == authUid()
            && request.resource.data.createdBy == authUid()
            && request.resource.data.visibleToUser is bool
            && request.resource.data.content is string
            && str(request.resource.data.content).size() > 0
            && request.resource.data.keys().hasOnly([
              "requestId",
              "staffId",
              "createdBy",
              "content",
              "visibleToUser",
              "progressPercent",
              "createdAt",
              "createdAtMs"
            ])
          );

        allow update, delete: if false;
      }

      match /attachments/{attachmentId} {
        allow read: if canReadRequestData(requestDoc(requestId));
        allow create: if canAdminAccessRequest(requestId) || isRequestOwner(requestId);
        allow update: if canAdminAccessRequest(requestId);

        allow delete: if canAdminAccessRequest(requestId)
          || (
            isRequestOwner(requestId)
            && (requestIsFinalized(requestId) || requestOwnerCanDeletePendingRequest())
          );
      }

      match /payments/{paymentId} {
        function ownerCanCreateUnlockPayment() {
          return requestOwnerCanDeletePendingRequest()
            && paymentId == (
              str(requestDoc(requestId).unlockPaymentId).size() > 0
                ? str(requestDoc(requestId).unlockPaymentId)
                : "unlock_request_payment"
            )
            && request.resource.data.keys().hasOnly([
              "requestId",
              "requestUid",
              "paymentType",
              "paymentLabel",
              "amount",
              "currency",
              "status",
              "createdAt",
              "createdAtMs",
              "updatedAt",
              "updatedAtMs"
            ])
            && request.resource.data.requestId == requestId
            && request.resource.data.requestUid == authUid()
            && lower(request.resource.data.paymentType) == "unlock_request"
            && request.resource.data.amount is number
            && request.resource.data.amount > 0
            && str(request.resource.data.currency).size() > 0
            && request.resource.data.status in [
              "draft",
              "payment_session_created",
              "awaiting_payment"
            ];
        }

        function ownerCanUpdateUnlockPayment() {
          return requestOwnerCanDeletePendingRequest()
            && paymentId == (
              str(requestDoc(requestId).unlockPaymentId).size() > 0
                ? str(requestDoc(requestId).unlockPaymentId)
                : "unlock_request_payment"
            )
            && resource.data.requestId == requestId
            && resource.data.requestUid == authUid()
            && lower(resource.data.paymentType) == "unlock_request"
            && request.resource.data.requestId == resource.data.requestId
            && request.resource.data.requestUid == resource.data.requestUid
            && request.resource.data.paymentType == resource.data.paymentType
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "status",
              "transactionReference",
              "providerReference",
              "providerTransactionId",
              "paymentMethod",
              "paidAt",
              "paidAtMs",
              "updatedAt",
              "updatedAtMs",
              "latestReference"
            ])
            && (
              request.resource.data.status == resource.data.status
              || (
                resource.data.status in ["draft", "payment_session_created", "awaiting_payment"]
                && request.resource.data.status in ["paid", "failed"]
              )
            )
            && (
              !changedHas("transactionReference")
              || str(request.resource.data.transactionReference).size() > 0
            );
        }

        allow read: if canReadRequestData(requestDoc(requestId));
        allow create: if ownerCanCreateUnlockPayment();
        allow update: if ownerCanUpdateUnlockPayment();
        allow delete: if canAdminAccessRequest(requestId)
          || (
            requestOwnerCanDeletePendingRequest()
            && lower(resource.data.status) in [
              "draft",
              "payment_session_created",
              "awaiting_payment",
              "failed",
              "revoked",
              "expired"
            ]
          );

        match /attempts/{attemptId} {
          allow read: if canReadRequestData(requestDoc(requestId));
          allow create, update, delete: if false;
        }
      }

      match /refundRequests/{refundId} {
        allow read: if canReadRequestData(requestDoc(requestId));
        allow create, update, delete: if false;
      }

      match /documentExtracts/{attachmentId} {
        function extractKeysOk() {
          return request.resource.data.keys().hasOnly([
            "attachmentId",
            "requestId",
            "status",
            "method",
            "docType",
            "fields",
            "confidence",
            "highlights",
            "notes",
            "updatedBy",
            "updatedAt",
            "createdAt"
          ]);
        }

        function extractStatusOk() {
          return request.resource.data.status in ["draft", "reviewed", "approved"];
        }

        function extractMethodOk() {
          return request.resource.data.method in ["template_v1", "ai_ocr_v1"];
        }

        allow read: if canAdminAccessRequest(requestId)
          || isRequestOwner(requestId)
          || isRequestAssignedStaff(requestId);

        allow create, update: if (canAdminAccessRequest(requestId) || isRequestAssignedStaff(requestId))
          && extractKeysOk()
          && extractStatusOk()
          && extractMethodOk()
          && request.resource.data.requestId == requestId
          && request.resource.data.attachmentId == attachmentId;

        allow delete: if canAdminAccessRequest(requestId);
      }

      match /messages/{messageId} {
        allow read: if canReadRequestData(requestDoc(requestId));
        allow create, update, delete: if canAdminAccessRequest(requestId);
      }

      match /pendingMessages/{pendingId} {
        allow read: if canAdminAccessRequest(requestId)
          || (
            signedIn()
            && resource.data.fromUid != null
            && resource.data.fromUid == authUid()
            && (isRequestOwner(requestId) || isRequestAssignedStaff(requestId))
          );

        allow create: if (isRequestOwner(requestId) || isRequestAssignedStaff(requestId))
          && request.resource.data.keys().hasOnly([
            "fromRole",
            "fromUid",
            "toRole",
            "type",
            "text",
            "pdfMeta",
            "status",
            "createdAt"
          ])
          && chatRoleOk(request.resource.data.fromRole)
          && chatRoleOk(request.resource.data.toRole)
          && chatTypeOk(request.resource.data.type)
          && request.resource.data.status == "pending"
          && request.resource.data.fromUid == authUid()
          && (
            (isRequestOwner(requestId)
              && request.resource.data.fromRole == "user"
              && request.resource.data.toRole == "staff")
            || (isRequestAssignedStaff(requestId)
              && request.resource.data.fromRole == "staff"
              && request.resource.data.toRole == "user")
          )
          && (
            (request.resource.data.type == "text" && str(request.resource.data.text).size() > 0)
            || (request.resource.data.type == "pdf" && request.resource.data.pdfMeta != null)
            || (
              request.resource.data.type == "bundle"
              && (
                str(request.resource.data.text).size() > 0
                || request.resource.data.pdfMeta != null
              )
            )
          );

        allow update, delete: if canAdminAccessRequest(requestId);
      }

      match /readState/{stateId} {
        allow read: if canAdminAccessRequest(requestId)
          || (
            signedIn() && (
              (stateId == ("user_" + requestOwner(requestId)) && authUid() == requestOwner(requestId))
              || (stateId == ("staff_" + requestAssignedTo(requestId)) && authUid() == requestAssignedTo(requestId))
            )
          );

        allow create, update: if canAdminAccessRequest(requestId)
          || (
            signedIn()
            && request.resource.data.keys().hasOnly(["role", "uid", "lastReadAt"])
            && (
              (stateId == ("user_" + requestOwner(requestId))
                && authUid() == requestOwner(requestId)
                && request.resource.data.role == "user"
                && request.resource.data.uid == requestOwner(requestId))
              || (stateId == ("staff_" + requestAssignedTo(requestId))
                && authUid() == requestAssignedTo(requestId)
                && request.resource.data.role == "staff"
                && request.resource.data.uid == requestAssignedTo(requestId))
            )
          );

        allow delete: if canAdminAccessRequest(requestId);
      }

      match /staffFileDrafts/{draftId} {
        function isDraftOwner() {
          return (resource.data.staffUid != null && resource.data.staffUid == authUid())
            || (resource.data.createdBy != null && resource.data.createdBy == authUid());
        }

        allow read: if canAdminAccessRequest(requestId) || isRequestAssignedStaff(requestId);

        allow create: if canAdminAccessRequest(requestId)
          || (
            isRequestAssignedStaff(requestId)
            && (
              request.resource.data.staffUid == authUid()
              || request.resource.data.createdBy == authUid()
            )
            && request.resource.data.keys().hasOnly([
              "name",
              "label",
              "url",
              "note",
              "staffUid",
              "createdBy",
              "createdAt",
              "updatedAt",
              "status"
            ])
          );

        allow update: if canAdminAccessRequest(requestId)
          || (
            isRequestAssignedStaff(requestId)
            && isDraftOwner()
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "name",
              "label",
              "url",
              "note",
              "updatedAt",
              "status"
            ])
          );

        allow delete: if canAdminAccessRequest(requestId)
          || (isRequestAssignedStaff(requestId) && isDraftOwner());
      }

      match /adminFileDrafts/{draftId} {
        function isStaffDraftAllowedCreate() {
          return isRequestAssignedStaff(requestId)
            && request.resource.data.fromStaff == true
            && request.resource.data.staffUid == authUid()
            && request.resource.data.keys().hasOnly([
              "name",
              "url",
              "fromStaff",
              "staffUid",
              "createdAt",
              "syncedAt",
              "updatedAt"
            ]);
        }

        function isStaffDraftAllowedUpdate() {
          return isRequestAssignedStaff(requestId)
            && resource.data.fromStaff == true
            && resource.data.staffUid == authUid()
            && request.resource.data.fromStaff == true
            && request.resource.data.staffUid == authUid()
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "name",
              "url",
              "syncedAt",
              "updatedAt"
            ]);
        }

        allow read: if canAdminAccessRequest(requestId) || isRequestAssignedStaff(requestId);
        allow create: if canAdminAccessRequest(requestId) || isStaffDraftAllowedCreate();
        allow update: if canAdminAccessRequest(requestId) || isStaffDraftAllowedUpdate();

        allow delete: if canAdminAccessRequest(requestId)
          || (
            isRequestAssignedStaff(requestId)
            && resource.data.fromStaff == true
            && resource.data.staffUid == authUid()
          );
      }

      match /adminFiles/{fileId} {
        allow read: if canReadRequestData(requestDoc(requestId));
        allow create, update, delete: if canAdminAccessRequest(requestId);
      }
    }

    match /applications/{appId} {
      allow create: if signedIn() && request.resource.data.uid == authUid();
      allow read: if isSuperAdmin() || (signedIn() && resource.data.uid == authUid());
      allow update, delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

