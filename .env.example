# Firebase Configuration
# Copy this to `.env.local` in the project root for your real local values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Storage Provider
# supabase (recommended) | firebase
VITE_STORAGE_PROVIDER=supabase
# Optional fallback if primary upload provider fails
VITE_STORAGE_FALLBACK_PROVIDER=firebase

# Supabase Storage Configuration (used when VITE_STORAGE_PROVIDER=supabase)
# Use your Supabase project URL and public anon key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=majuu-files

# Payment Settings
VITE_PAYMENT_MODE=demo
VITE_PAYMENT_API_BASE_URL=http://localhost:5000
VITE_PAYMENT_DEBUG=true

# App Settings
# VITE_APP_BASE_URL=http://localhost:5173
