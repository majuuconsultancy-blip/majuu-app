# Firebase Configuration
# Copy this to `.env.local` in the project root for your real local values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Storage Provider
# supabase (recommended) | firebase
VITE_STORAGE_PROVIDER=supabase
# Optional fallback if primary upload provider fails.
# Leave blank during Supabase testing so failures stay visible instead of silently mixing providers.
VITE_STORAGE_FALLBACK_PROVIDER=

# Supabase Storage Configuration (used when VITE_STORAGE_PROVIDER=supabase)
# Use your Supabase project URL and public anon key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=majuu-files

# Payment / API Settings
# Optional when the API is served from a different origin.
# VITE_API_BASE_URL=https://majuuapp.vercel.app
VITE_PAYMENT_DEBUG=false

# Firebase Admin / Vercel API routes
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# M-Pesa (Daraja) server runtime
# For sandbox use MPESA_ENVIRONMENT=test and your Daraja sandbox credentials.
# Keep the callback URL public so Safaricom can reach /api/mpesa-callback.
MPESA_ENVIRONMENT=test
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_PAYBILL=174379
MPESA_SHORTCODE_TYPE=paybill
MPESA_INITIATOR_NAME=testapi
# Example: https://majuuapp.vercel.app/api/mpesa-callback
MPESA_CALLBACK_URL=

# Optional frontend/public URL helpers for callback screen redirects and link generation.
FRONTEND_APP_BASE_URL=
PAYMENT_FRONTEND_CALLBACK_PATH=/payment/callback

# App Settings
# VITE_APP_BASE_URL=http://localhost:5173
